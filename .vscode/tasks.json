{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Sync: git pull（GitHub の最新を手元に取り込む）",
      "type": "shell",
      "command": "git pull --ff-only",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen",
        "instanceLimit": 1
      }
    }
  ]
}
